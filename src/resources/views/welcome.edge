<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{{app_name}} — Image Placeholder Service</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@toneflix" />
  <meta name="twitter:title" content="{{app_name}}" />
  <meta name="twitter:description"
    content="Drop-in placeholder images for every project. Random, seeded, categorised, or specific" />
  <meta name="twitter:image"
    content="{{config('app.url')}}/category/fashion/800/600.jpg?seed=spray&filters=greyscale" />
  <meta property="og:type" content="article" />
  <meta property="og:title" content="{{app_name}}" />
  <meta property="og:description"
    content="Drop-in placeholder images for every project. Random, seeded, categorised, or specific" />
  <meta property="og:url" content="{{config('app.url')}}/" />
  <meta property="og:image" content="{{config('app.url')}}/category/fashion/800/600.jpg?seed=spray&filters=greyscale" />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap"
    rel="stylesheet" />
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --ink: #0e0e0f;
      --ink-2: #3a3a40;
      --ink-3: #7a7a85;
      --surface: #f5f4f0;
      --surface-2: #eceae3;
      --surface-3: #e1dfd7;
      --accent: #e85d26;
      --accent-2: #f28c5e;
      --line: rgba(14, 14, 15, 0.1);
      --mono: 'DM Mono', monospace;
      --serif: 'DM Serif Display', serif;
      --sans: 'DM Sans', sans-serif;
      --r: 6px;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      background: var(--surface);
      color: var(--ink);
      font-family: var(--sans);
      font-size: 16px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    /* ── NAV ── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 3rem;
      height: 60px;
      background: var(--surface);
      border-bottom: 1px solid var(--line);
    }

    .logo {
      font-family: var(--serif);
      font-size: 1.4rem;
      letter-spacing: -0.02em;
      color: var(--ink);
      text-decoration: none;
    }

    .logo span {
      color: var(--accent);
    }

    nav ul {
      list-style: none;
      display: flex;
      gap: 2rem;
    }

    nav ul a {
      font-size: 0.875rem;
      font-weight: 400;
      color: var(--ink-2);
      text-decoration: none;
      transition: color 0.15s;
    }

    nav ul a:hover {
      color: var(--accent);
    }

    a.inline {
      color: var(--accent);
    }

    a.inline:hover {
      color: var(--accent-2);
    }

    .nav-cta {
      font-family: var(--mono);
      font-size: 0.78rem;
      font-weight: 500;
      color: var(--accent) !important;
      border: 1px solid var(--accent);
      padding: 0.3rem 0.9rem;
      border-radius: var(--r);
      transition: background 0.15s, color 0.15s !important;
    }

    .nav-cta:hover {
      background: var(--accent) !important;
      color: #fff !important;
    }

    /* ── HERO ── */
    .hero {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: calc(100vh - 60px);
      align-items: center;
    }

    .hero-left {
      padding: 5rem 3rem;
      border-right: 1px solid var(--line);
    }

    .hero-tag {
      display: inline-block;
      font-family: var(--mono);
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      background: rgba(232, 93, 38, 0.08);
      padding: 0.3rem 0.75rem;
      border-radius: 100px;
      margin-bottom: 1.5rem;
    }

    .hero-left h1 {
      font-family: var(--serif);
      font-size: clamp(3rem, 5vw, 5.5rem);
      line-height: 1.05;
      letter-spacing: -0.03em;
      margin-bottom: 1.5rem;
    }

    .hero-left h1 em {
      font-style: italic;
      color: var(--accent);
    }

    .hero-left p {
      font-size: 1.1rem;
      font-weight: 300;
      color: var(--ink-2);
      max-width: 440px;
      margin-bottom: 2.5rem;
      line-height: 1.7;
    }

    .hero-actions {
      display: flex;
      gap: 1rem;
      align-items: center;
      flex-wrap: wrap;
    }

    .btn-primary {
      font-family: var(--sans);
      font-size: 0.9rem;
      font-weight: 500;
      color: #fff;
      background: var(--ink);
      padding: 0.65rem 1.5rem;
      border-radius: var(--r);
      text-decoration: none;
      transition: background 0.15s, transform 0.1s;
    }

    .btn-primary:hover {
      background: var(--accent);
      transform: translateY(-1px);
    }

    .btn-ghost {
      font-family: var(--mono);
      font-size: 0.8rem;
      color: var(--ink-2);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.4rem;
      transition: color 0.15s;
    }

    .btn-ghost:hover {
      color: var(--accent);
    }

    .btn-ghost svg {
      width: 16px;
      height: 16px;
    }

    .hero-right {
      background: var(--surface-2);
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 3rem;
      gap: 1.25rem;
    }

    .url-demo {
      background: var(--ink);
      border-radius: var(--r);
      padding: 1.1rem 1.4rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      animation: fadeUp 0.4s ease both;
    }

    .url-demo:nth-child(1) {
      animation-delay: 0.05s;
    }

    .url-demo:nth-child(2) {
      animation-delay: 0.15s;
    }

    .url-demo:nth-child(3) {
      animation-delay: 0.25s;
    }

    .url-demo:nth-child(4) {
      animation-delay: 0.35s;
    }

    .url-badge {
      font-family: var(--mono);
      font-size: 0.65rem;
      font-weight: 500;
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      flex-shrink: 0;
    }

    .badge-get {
      background: rgba(99, 201, 102, 0.2);
      color: #63c966;
    }

    .url-demo code {
      font-family: var(--mono);
      font-size: 0.82rem;
      color: rgba(255, 255, 255, 0.85);
      word-break: break-all;
    }

    .url-demo code .hl {
      color: var(--accent-2);
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(8px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* ── STATS BAR ── */
    .stats {
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      display: flex;
    }

    .stat {
      flex: 1;
      padding: 1.75rem 2rem;
      border-right: 1px solid var(--line);
    }

    .stat:last-child {
      border-right: none;
    }

    .stat-num {
      font-family: var(--serif);
      font-size: 2.4rem;
      line-height: 1;
      margin-bottom: 0.25rem;
    }

    .stat-label {
      font-size: 0.8rem;
      font-weight: 400;
      color: var(--ink-3);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    /* ── SAMPLES ── */
    #samples {
      padding: 5rem 3rem;
      border-bottom: 1px solid var(--line);
    }

    .samples-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 2rem;
    }

    .samples-header .section-title {
      margin-bottom: 0;
    }

    .samples-reload {
      font-family: var(--mono);
      font-size: 0.78rem;
      font-weight: 500;
      color: var(--ink-2);
      background: none;
      border: 1px solid var(--surface-3);
      border-radius: var(--r);
      padding: 0.4rem 0.9rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 0.4rem;
      transition: border-color 0.15s, color 0.15s;
    }

    .samples-reload:hover {
      border-color: var(--ink-2);
      color: var(--ink);
    }

    .samples-reload svg {
      width: 13px;
      height: 13px;
      transition: transform 0.4s;
    }

    .samples-reload.spinning svg {
      transform: rotate(360deg);
    }

    /* masonry-like mosaic */
    .mosaic {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: 180px;
      gap: 8px;
    }

    .mosaic-item {
      position: relative;
      overflow: hidden;
      border-radius: var(--r);
      background: var(--surface-2);
      cursor: default;
    }

    .mosaic-item.tall {
      grid-row: span 2;
    }

    .mosaic-item.wide {
      grid-column: span 2;
    }

    .mosaic-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.35s ease, opacity 0.25s;
      opacity: 0;
    }

    .mosaic-item img.loaded {
      opacity: 1;
    }

    .mosaic-item:hover img {
      transform: scale(1.04);
    }

    .mosaic-caption {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 0.5rem 0.75rem;
      background: linear-gradient(transparent, rgba(14, 14, 15, 0.65));
      font-family: var(--mono);
      font-size: 0.65rem;
      color: rgba(255, 255, 255, 0.8);
      letter-spacing: 0.05em;
      text-transform: uppercase;
      opacity: 0;
      transition: opacity 0.2s;
    }

    .mosaic-item:hover .mosaic-caption {
      opacity: 1;
    }

    /* filter pill shown on each tile */
    .mosaic-pill {
      position: absolute;
      top: 0.6rem;
      right: 0.6rem;
      font-family: var(--mono);
      font-size: 0.6rem;
      font-weight: 500;
      padding: 0.2rem 0.5rem;
      border-radius: 100px;
      letter-spacing: 0.06em;
      background: rgba(14, 14, 15, 0.55);
      color: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(4px);
    }

    /* ── SECTION WRAPPER ── */
    section {
      padding: 5rem 3rem;
    }

    .section-tag {
      font-family: var(--mono);
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--ink-3);
      margin-bottom: 0.75rem;
    }

    .section-title {
      font-family: var(--serif);
      font-size: clamp(2rem, 3vw, 3rem);
      line-height: 1.1;
      letter-spacing: -0.02em;
      margin-bottom: 1rem;
    }

    .section-sub {
      font-size: 1rem;
      font-weight: 300;
      color: var(--ink-2);
      max-width: 560px;
      line-height: 1.7;
      margin-bottom: 3rem;
    }

    /* ── ENDPOINTS TABLE ── */
    .endpoints {
      max-width: 900px;
      margin: 0 auto;
    }

    .ep-group {
      margin-bottom: 2.5rem;
    }

    .ep-group-title {
      font-family: var(--mono);
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--ink-3);
      padding: 0 0 0.5rem;
      border-bottom: 1px solid var(--line);
      margin-bottom: 0;
    }

    .ep-row {
      display: grid;
      grid-template-columns: 70px 1fr auto;
      align-items: start;
      padding: 0.9rem 0;
      border-bottom: 1px solid var(--line);
      gap: 1rem;
    }

    .ep-method {
      font-family: var(--mono);
      font-size: 0.68rem;
      font-weight: 500;
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      background: rgba(99, 201, 102, 0.15);
      color: #3a9c3d;
      text-align: center;
      margin-top: 2px;
    }

    .ep-param-badge {
      background: rgba(99, 160, 255, 0.15);
      color: #3a6fc9;
    }

    .ep-path {
      font-family: var(--mono);
      font-size: 0.85rem;
      color: var(--ink);
    }

    .ep-path .ep-param {
      color: var(--accent);
    }

    .ep-desc {
      font-size: 0.8rem;
      color: var(--ink-3);
      margin-top: 0.2rem;
    }

    .ep-badge-new {
      font-family: var(--mono);
      font-size: 0.62rem;
      font-weight: 500;
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
      background: rgba(232, 93, 38, 0.1);
      color: var(--accent);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      white-space: nowrap;
      align-self: center;
    }

    /* ── FILTERS GRID ── */
    #filters {
      background: var(--surface-2);
    }

    .filters-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1px;
      background: var(--line);
      border: 1px solid var(--line);
      border-radius: var(--r);
      overflow: hidden;
    }

    .filter-card {
      background: var(--surface);
      padding: 1.5rem;
    }

    .filter-name {
      font-family: var(--mono);
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--ink);
      margin-bottom: 0.3rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .filter-param {
      font-family: var(--mono);
      font-size: 0.72rem;
      color: var(--accent-2);
      background: rgba(232, 93, 38, 0.08);
      padding: 0.1rem 0.4rem;
      border-radius: 4px;
    }

    .filter-desc {
      font-size: 0.8rem;
      color: var(--ink-3);
      margin-bottom: 0.75rem;
    }

    .filter-example {
      font-family: var(--mono);
      font-size: 0.72rem;
      color: var(--ink-3);
      background: var(--surface-2);
      padding: 0.4rem 0.7rem;
      border-radius: 4px;
      word-break: break-all;
    }

    /* ── PLAYGROUND ── */
    #playground {
      border-top: 1px solid var(--line);
    }

    .playground-inner {
      display: grid;
      grid-template-columns: 340px 1fr;
      gap: 2rem;
      align-items: start;
      max-width: 1000px;
    }

    .pg-form {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    label {
      font-size: 0.78rem;
      font-weight: 500;
      color: var(--ink-2);
      letter-spacing: 0.03em;
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }

    input[type=text],
    input[type=number],
    select {
      font-family: var(--mono);
      font-size: 0.82rem;
      color: var(--ink);
      background: var(--surface);
      border: 1px solid var(--surface-3);
      border-radius: var(--r);
      padding: 0.55rem 0.8rem;
      outline: none;
      transition: border-color 0.15s;
      width: 100%;
    }

    input:focus,
    select:focus {
      border-color: var(--ink-2);
    }

    .pg-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
    }

    .checkbox-group {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .chip {
      font-family: var(--mono);
      font-size: 0.72rem;
      font-weight: 500;
      padding: 0.3rem 0.7rem;
      border-radius: 100px;
      border: 1px solid var(--surface-3);
      background: var(--surface);
      cursor: pointer;
      user-select: none;
      transition: background 0.12s, border-color 0.12s, color 0.12s;
      color: var(--ink-2);
    }

    .chip.active {
      background: var(--ink);
      border-color: var(--ink);
      color: #fff;
    }

    .pg-generate {
      font-family: var(--sans);
      font-size: 0.9rem;
      font-weight: 500;
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: var(--r);
      padding: 0.7rem 1.25rem;
      cursor: pointer;
      width: 100%;
      transition: background 0.15s, transform 0.1s;
      margin-top: 0.25rem;
    }

    .pg-generate:hover {
      background: #c94d1e;
      transform: translateY(-1px);
    }

    .pg-preview {
      border: 1px solid var(--surface-3);
      border-radius: var(--r);
      overflow: hidden;
      background: var(--surface-2);
      min-height: 300px;
      display: flex;
      flex-direction: column;
    }

    .pg-preview img {
      width: 100%;
      height: 320px;
      object-fit: cover;
      display: block;
    }

    .pg-url-bar {
      padding: 0.75rem 1rem;
      background: var(--ink);
      font-family: var(--mono);
      font-size: 0.75rem;
      color: rgba(255, 255, 255, 0.7);
      word-break: break-all;
      line-height: 1.5;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .pg-copy {
      font-family: var(--mono);
      font-size: 0.68rem;
      font-weight: 500;
      color: var(--accent-2);
      background: none;
      border: 1px solid rgba(242, 140, 94, 0.4);
      border-radius: 4px;
      padding: 0.2rem 0.55rem;
      cursor: pointer;
      flex-shrink: 0;
      transition: background 0.12s;
    }

    .pg-copy:hover {
      background: rgba(242, 140, 94, 0.12);
    }

    .pg-placeholder {
      display: flex;
      align-items: center;
      justify-content: center;
      flex: 1;
      color: var(--ink-3);
      font-size: 0.85rem;
      font-family: var(--mono);
      flex-direction: column;
      gap: 0.5rem;
      padding: 2rem;
    }

    .pg-placeholder svg {
      opacity: 0.3;
      width: 40px;
      height: 40px;
    }

    /* ── FOOTER ── */
    footer {
      border-top: 1px solid var(--line);
      padding: 2rem 3rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 0.8rem;
      color: var(--ink-3);
    }

    footer a {
      color: var(--ink-3);
      text-decoration: none;
    }

    footer a:hover {
      color: var(--accent);
    }

    /* ── API SECTION ── */
    #api {
      border-top: 1px solid var(--line);
    }

    .api-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      max-width: 1000px;
    }

    .api-block {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .api-route {
      background: var(--ink);
      border-radius: var(--r);
      padding: 1rem 1.25rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .api-route code {
      font-family: var(--mono);
      font-size: 0.82rem;
      color: rgba(255, 255, 255, 0.85);
      word-break: break-all;
    }

    .api-route code .hl {
      color: var(--accent-2);
    }

    .api-desc {
      font-size: 0.85rem;
      font-weight: 300;
      color: var(--ink-2);
      line-height: 1.6;
    }

    .api-response {
      background: var(--surface-2);
      border: 1px solid var(--surface-3);
      border-radius: var(--r);
      overflow: hidden;
    }

    .api-response-bar {
      padding: 0.5rem 1rem;
      background: var(--surface-3);
      font-family: var(--mono);
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--ink-3);
      border-bottom: 1px solid var(--line);
    }

    .api-response pre {
      font-family: var(--mono);
      font-size: 0.75rem;
      line-height: 1.65;
      color: var(--ink-2);
      padding: 1rem 1.25rem;
      overflow-x: auto;
      margin: 0;
    }

    .api-response pre .key {
      color: var(--ink);
    }

    .api-response pre .str {
      color: #3a7c4e;
    }

    .api-response pre .num {
      color: #3a6fc9;
    }

    .api-params {
      display: flex;
      flex-direction: column;
      gap: 0;
      border: 1px solid var(--surface-3);
      border-radius: var(--r);
      overflow: hidden;
    }

    .api-param {
      display: grid;
      grid-template-columns: 110px 60px 1fr;
      gap: 1rem;
      padding: 0.65rem 1rem;
      border-bottom: 1px solid var(--line);
      align-items: baseline;
    }

    .api-param:last-child {
      border-bottom: none;
    }

    .api-param-name {
      font-family: var(--mono);
      font-size: 0.75rem;
      color: var(--accent);
    }

    .api-param-default {
      font-family: var(--mono);
      font-size: 0.72rem;
      color: var(--ink-3);
    }

    .api-param-desc {
      font-size: 0.78rem;
      color: var(--ink-3);
    }

    @media (max-width: 820px) {
      .api-grid {
        grid-template-columns: 1fr;
      }
    }

    /* ── CATEGORIES ── */
    #categories {
      background: var(--surface-2);
      border-bottom: 1px solid var(--line);
    }

    .categories-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1px;
      background: var(--line);
      border: 1px solid var(--line);
      border-radius: var(--r);
      overflow: hidden;
    }

    .cat-card {
      position: relative;
      overflow: hidden;
      background: var(--surface-3);
      aspect-ratio: 4/3;
      cursor: default;
      text-decoration: none;
      display: block;
    }

    .cat-card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.4s ease, opacity 0.3s;
      opacity: 0;
    }

    .cat-card img.loaded {
      opacity: 1;
    }

    .cat-card:hover img {
      transform: scale(1.06);
    }

    .cat-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(14, 14, 15, 0.75) 0%, rgba(14, 14, 15, 0.1) 55%, transparent 100%);
      transition: background 0.3s;
    }

    .cat-card:hover .cat-overlay {
      background: linear-gradient(to top, rgba(14, 14, 15, 0.85) 0%, rgba(14, 14, 15, 0.25) 60%, transparent 100%);
    }

    .cat-info {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 1rem;
    }

    .cat-name {
      font-family: var(--serif);
      font-size: 1.05rem;
      color: #fff;
      line-height: 1.2;
      margin-bottom: 0.3rem;
      text-transform: capitalize;
    }

    .cat-url {
      font-family: var(--mono);
      font-size: 0.62rem;
      color: rgba(255, 255, 255, 0.55);
      letter-spacing: 0.04em;
      display: flex;
      align-items: center;
      gap: 0.35rem;
      transition: color 0.15s;
    }

    .cat-card:hover .cat-url {
      color: var(--accent-2);
    }

    /* shimmer while image loads */
    .cat-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, var(--surface-3) 25%, var(--surface-2) 50%, var(--surface-3) 75%);
      background-size: 200% 100%;
      animation: shimmer 1.4s infinite;
    }

    .cat-card img.loaded~.cat-card::before,
    .cat-card:has(img.loaded)::before {
      display: none;
    }

    @keyframes shimmer {
      0% {
        background-position: 200% 0;
      }

      100% {
        background-position: -200% 0;
      }
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 820px) {
      nav {
        padding: 0 1.5rem;
      }

      nav ul {
        display: none;
      }

      .hero {
        grid-template-columns: 1fr;
        min-height: auto;
      }

      .hero-left {
        padding: 3rem 1.5rem;
        border-right: none;
        border-bottom: 1px solid var(--line);
      }

      .hero-right {
        padding: 2rem 1.5rem;
      }

      .stats {
        flex-wrap: wrap;
      }

      .stat {
        border-right: none;
        border-bottom: 1px solid var(--line);
      }

      #samples {
        padding: 3rem 1.5rem;
      }

      #categories {
        padding: 3rem 1.5rem;
      }

      .categories-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .mosaic {
        grid-template-columns: repeat(2, 1fr);
      }

      .mosaic-item.wide {
        grid-column: span 1;
      }

      section {
        padding: 3rem 1.5rem;
      }

      .playground-inner {
        grid-template-columns: 1fr;
      }

      footer {
        flex-direction: column;
        gap: 0.5rem;
        text-align: center;
      }
    }
  </style>
</head>

<body>

  <nav>
    <a class="logo" href="#"><span>{{app_name}}</span></a>
    <ul>
      <li><a href="#samples">Examples</a></li>
      <li><a href="#categories">Categories</a></li>
      <li><a href="#endpoints">Endpoints</a></li>
      <li><a href="#api">API</a></li>
      <li><a href="#filters">Filters</a></li>
      <li><a href="#playground">Playground</a></li>
      <li><a class="nav-cta" href="#playground">Try it →</a></li>
    </ul>
  </nav>

  <div class="hero">
    <div class="hero-left">
      <div class="hero-tag">Open-source · MIT licence</div>
      <h1>Beautiful<br /><em>placeholder</em><br />images, fast.</h1>
      <p>Drop-in placeholder images for every project. Random, seeded, categorised, or specific - Built with
        <a class="inline" target="_blank" href="https://arkstack.toneflix.net">Arkstack</a>.
      </p>
      <div class="hero-actions">
        <a class="btn-primary" href="#playground">Explore the API</a>
        <a class="btn-ghost" href="https://github.com/arkstack-tmp/pictwo" target="_blank">
          <svg viewBox="0 0 16 16" fill="currentColor">
            <path
              d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
          </svg>
          View on GitHub
        </a>
      </div>
    </div>

    <div class="hero-right">
      <div class="url-demo">
        <span class="url-badge badge-get">GET</span>
        <code>/<span class="hl">800</span>/600</code>
      </div>
      <div class="url-demo">
        <span class="url-badge badge-get">GET</span>
        <code>/id/<span class="hl">10001</span>/400/300.webp</code>
      </div>
      <div class="url-demo">
        <span class="url-badge badge-get">GET</span>
        <code>/category/<span class="hl">nature</span>/600/400</code>
      </div>
      <div class="url-demo">
        <span class="url-badge badge-get">GET</span>
        <code>/images/<span class="hl">avatar</span>?w=200&amp;h=200&amp;filters=greyscale</code>
      </div>
    </div>
  </div>

  <div class="stats">
    <div class="stat">
      <div class="stat-num">7</div>
      <div class="stat-label">Image formats</div>
    </div>
    <div class="stat">
      <div class="stat-num">6+</div>
      <div class="stat-label">Filter effects</div>
    </div>
    <div class="stat">
      <div class="stat-num">∞</div>
      <div class="stat-label">Seeds</div>
    </div>
    <div class="stat">
      <div class="stat-num">0ms</div>
      <div class="stat-label">Cold start</div>
    </div>
  </div>

  <!-- SAMPLES -->
  <div id="samples">
    <div class="samples-header">
      <div>
        <div class="section-tag">Live samples</div>
        <div class="section-title">See it in action</div>
      </div>
      <button class="samples-reload" id="reload-btn" onclick="reloadSamples()">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
          <path d="M13.5 2.5A6.5 6.5 0 1 1 2.5 8" />
          <polyline points="0,4 2.5,8 5,4" />
        </svg>
        New set
      </button>
    </div>

    <div class="mosaic" id="mosaic">

      <!-- tile 0: tall + wide (2 col, 2 row) -->
      <div class="mosaic-item tall wide" data-w="760" data-h="368" data-route="random">
        <img alt="random placeholder" />
        <div class="mosaic-caption">random · 760×368</div>
        <span class="mosaic-pill">random</span>
      </div>

      <!-- tile 1: tall (1 col, 2 row) -->
      <div class="mosaic-item tall" data-w="368" data-h="368" data-route="seed" data-seed="sunrise">
        <img alt="seeded placeholder" />
        <div class="mosaic-caption">seed: sunrise</div>
        <span class="mosaic-pill">seeded</span>
      </div>

      <!-- tile 2: normal (1 col, 1 row) -->
      <div class="mosaic-item" data-w="368" data-h="180" data-route="filter" data-filter="greyscale">
        <img alt="greyscale placeholder" />
        <div class="mosaic-caption">greyscale</div>
        <span class="mosaic-pill">greyscale</span>
      </div>

      <!-- tile 3: normal (1 col, 1 row) -->
      <div class="mosaic-item" data-w="368" data-h="180" data-route="filter" data-filter="blur:6">
        <img alt="blur placeholder" />
        <div class="mosaic-caption">blur · sigma 6</div>
        <span class="mosaic-pill">blur</span>
      </div>

      <!-- tile 5: wide (2 col, 1 row) -->
      <div class="mosaic-item wide" data-w="760" data-h="180" data-route="category" data-cat="technology">
        <img alt="technology category" />
        <div class="mosaic-caption">category · technology</div>
        <span class="mosaic-pill">category</span>
      </div>

      <!-- tile 6: normal (1 col, 1 row) -->
      <div class="mosaic-item" data-w="368" data-h="180" data-route="filter" data-filter="sharpen,normalize">
        <img alt="sharpen+normalize placeholder" />
        <div class="mosaic-caption">sharpen + normalize</div>
        <span class="mosaic-pill">multi-filter</span>
      </div>

    </div>
  </div>

  <!-- CATEGORIES -->
  <section id="categories">
    <div class="section-tag">Browse</div>
    <div class="section-title">Available Categories</div>
    <p class="section-sub">Every category maps directly to a URL segment. Use it with either route style.</p>

    <div class="categories-grid" id="categories-grid">

      <a class="cat-card" href="#playground" data-cat="african-fashion" onclick="prefillCategory('african-fashion')">
        <img alt="african-fashion" />
        <div class="cat-overlay"></div>
        <div class="cat-info">
          <div class="cat-name">African Fashion</div>
          <div class="cat-url">/images/african-fashion</div>
        </div>
      </a>

      <a class="cat-card" href="#playground" data-cat="album" onclick="prefillCategory('album')">
        <img alt="album" />
        <div class="cat-overlay"></div>
        <div class="cat-info">
          <div class="cat-name">Album</div>
          <div class="cat-url">/images/album</div>
        </div>
      </a>

      <a class="cat-card" href="#playground" data-cat="avatar" onclick="prefillCategory('avatar')">
        <img alt="avatar" />
        <div class="cat-overlay"></div>
        <div class="cat-info">
          <div class="cat-name">Avatar</div>
          <div class="cat-url">/images/avatar</div>
        </div>
      </a>

      <a class="cat-card" href="#playground" data-cat="event" onclick="prefillCategory('event')">
        <img alt="event" />
        <div class="cat-overlay"></div>
        <div class="cat-info">
          <div class="cat-name">Event</div>
          <div class="cat-url">/images/event</div>
        </div>
      </a>

      <a class="cat-card" href="#playground" data-cat="fashion" onclick="prefillCategory('fashion')">
        <img alt="fashion" />
        <div class="cat-overlay"></div>
        <div class="cat-info">
          <div class="cat-name">Fashion</div>
          <div class="cat-url">/images/fashion</div>
        </div>
      </a>

      <a class="cat-card" href="#playground" data-cat="nature" onclick="prefillCategory('nature')">
        <img alt="nature" />
        <div class="cat-overlay"></div>
        <div class="cat-info">
          <div class="cat-name">Nature</div>
          <div class="cat-url">/images/nature</div>
        </div>
      </a>

      <a class="cat-card" href="#playground" data-cat="people" onclick="prefillCategory('people')">
        <img alt="people" />
        <div class="cat-overlay"></div>
        <div class="cat-info">
          <div class="cat-name">People</div>
          <div class="cat-url">/images/people</div>
        </div>
      </a>

      <a class="cat-card" href="#playground" data-cat="poster" onclick="prefillCategory('poster')">
        <img alt="poster" />
        <div class="cat-overlay"></div>
        <div class="cat-info">
          <div class="cat-name">Poster</div>
          <div class="cat-url">/images/poster</div>
        </div>
      </a>

      <a class="cat-card" href="#playground" data-cat="technology" onclick="prefillCategory('technology')">
        <img alt="technology" />
        <div class="cat-overlay"></div>
        <div class="cat-info">
          <div class="cat-name">Technology</div>
          <div class="cat-url">/images/technology</div>
        </div>
      </a>

    </div>
  </section>

  <!-- ENDPOINTS -->
  <section id="endpoints">
    <div class="section-tag">Reference</div>
    <div class="section-title">API Endpoints</div>
    <p class="section-sub">Two compatible URL styles — Picsum-style path params and Lorem Toneflix-style query params.
      Mix and match freely.</p>

    <div class="endpoints">

      <div class="ep-group">
        <div class="ep-group-title">Picsum-style</div>
        <div class="ep-row">
          <span class="ep-method">GET</span>
          <div>
            <div class="ep-path">/<span class="ep-param">{width}</span></div>
            <div class="ep-desc">Random image, square crop to width × width</div>
          </div><span></span>
        </div>
        <div class="ep-row">
          <span class="ep-method">GET</span>
          <div>
            <div class="ep-path">/<span class="ep-param">{width}</span>/<span class="ep-param">{height}</span></div>
            <div class="ep-desc">Random image, exact dimensions. Append .webp / .avif / .png for format.</div>
          </div><span></span>
        </div>
        <div class="ep-row">
          <span class="ep-method">GET</span>
          <div>
            <div class="ep-path">/id/<span class="ep-param">{id}</span>/<span class="ep-param">{width}</span>/<span
                class="ep-param">{height}</span></div>
            <div class="ep-desc">Deterministic: always returns the same image by file ID</div>
          </div><span></span>
        </div>
        <div class="ep-row">
          <span class="ep-method">GET</span>
          <div>
            <div class="ep-path">/seed/<span class="ep-param">{seed}</span>/<span class="ep-param">{width}</span>/<span
                class="ep-param">{height}</span></div>
            <div class="ep-desc">Seeded random: same seed always returns same image</div>
          </div><span></span>
        </div>
        <div class="ep-row">
          <span class="ep-method">GET</span>
          <div>
            <div class="ep-path">/category/<span class="ep-param">{category}</span>/<span
                class="ep-param">{width}</span>/<span class="ep-param">{height}</span></div>
            <div class="ep-desc">Random image from a specific category, resized to dimensions</div>
          </div>
          <span class="ep-badge-new">New</span>
        </div>
      </div>

      <div class="ep-group">
        <div class="ep-group-title">Lorem Toneflix–compatible <code
            style="font-size:0.72rem;color:var(--ink-3)">/images/*</code></div>
        <div class="ep-row">
          <span class="ep-method">GET</span>
          <div>
            <div class="ep-path">/images</div>
            <div class="ep-desc">Random image. Use <code style="font-family:var(--mono);font-size:0.8em">?w=</code> and
              <code style="font-family:var(--mono);font-size:0.8em">?h=</code> to set dimensions.
            </div>
          </div><span></span>
        </div>
        <div class="ep-row">
          <span class="ep-method">GET</span>
          <div>
            <div class="ep-path">/images/<span class="ep-param">{category}</span></div>
            <div class="ep-desc">Random image from category. Supports avatar, nature, technology, etc.</div>
          </div><span></span>
        </div>
        <div class="ep-row">
          <span class="ep-method">GET</span>
          <div>
            <div class="ep-path">/images/image/<span class="ep-param">{id}</span></div>
            <div class="ep-desc">Specific image by file ID. Combine with <code
                style="font-family:var(--mono);font-size:0.8em">?text=true</code> to discover IDs.</div>
          </div><span></span>
        </div>
      </div>

      <div class="ep-group">
        <div class="ep-group-title">Shared query parameters</div>
        <div class="ep-row">
          <span class="ep-method ep-param-badge">PARAM</span>
          <div>
            <div class="ep-path">?w=<span class="ep-param">N</span> &amp;h=<span class="ep-param">N</span></div>
            <div class="ep-desc">Output width / height (Lorem Toneflix style). Alias for path params.</div>
          </div><span></span>
        </div>
        <div class="ep-row">
          <span class="ep-method ep-param-badge">PARAM</span>
          <div>
            <div class="ep-path">?filters=<span class="ep-param">f1,f2:v</span></div>
            <div class="ep-desc">Comma-separated filters with optional values. E.g. <code
                style="font-family:var(--mono);font-size:0.8em">?filters=greyscale,blur:5</code></div>
          </div><span></span>
        </div>
        <div class="ep-row">
          <span class="ep-method ep-param-badge">PARAM</span>
          <div>
            <div class="ep-path">?text=<span class="ep-param">true|string</span></div>
            <div class="ep-desc">Overlay text on the image. Pass <code
                style="font-family:var(--mono);font-size:0.8em">true</code> to use the image file name.</div>
          </div><span></span>
        </div>
        <div class="ep-row">
          <span class="ep-method ep-param-badge">PARAM</span>
          <div>
            <div class="ep-path">?seed=<span class="ep-param">anything</span></div>
            <div class="ep-desc">Deterministic random. Any unknown query param also acts as a seed.</div>
          </div><span></span>
        </div>
      </div>

    </div>
  </section>

  <section id="api">
    <div class="section-tag">JSON API</div>
    <div class="section-title">API Routes</div>
    <p class="section-sub">Inspect the image catalogue programmatically. All routes return JSON and require no
      authentication.</p>

    <div class="api-grid">

      <div class="api-block">
        <div class="api-route">
          <span class="url-badge badge-get">GET</span>
          <code>/api/v1/list</code>
        </div>
        <p class="api-desc">Returns a paginated list of every image across all categories.</p>

        <div class="api-params">
          <div class="api-param" style="background:var(--surface-2);border-bottom:1px solid var(--line)">
            <span
              style="font-family:var(--mono);font-size:0.65rem;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;color:var(--ink-3)">Param</span>
            <span
              style="font-family:var(--mono);font-size:0.65rem;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;color:var(--ink-3)">Default</span>
            <span
              style="font-family:var(--mono);font-size:0.65rem;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;color:var(--ink-3)">Description</span>
          </div>
          <div class="api-param">
            <span class="api-param-name">?page</span>
            <span class="api-param-default">1</span>
            <span class="api-param-desc">Page number, 1-based</span>
          </div>
          <div class="api-param">
            <span class="api-param-name">?limit</span>
            <span class="api-param-default">30</span>
            <span class="api-param-desc">Items per page</span>
          </div>
        </div>

        <div class="api-response">
          <div class="api-response-bar">Response · array</div>
          <pre>{
  <span class="key">"data"</span>: [
    {
      <span class="key">"id"</span>: <span class="str">"60059"</span>,
      <span class="key">"url"</span>: <span class="str">"https://pictwo.toneflix.net/id/60059/info"</span>,
      <span class="key">"width"</span>: <span class="num">800</span>,
      <span class="key">"height"</span>: <span class="num">600</span>,
      <span class="key">"category"</span>: <span class="str">"technology"</span>,
      <span class="key">"download_url"</span>: <span class="str">"https://pictwo.toneflix.net/id/60059/800/600"</span>
    }
  ],
  <span class="key">"links"</span>: {
    <span class="key">"prev"</span>: <span class="str">"https://pictwo.toneflix.net/api/v1/list?page=1&amp;limit=30"</span>,
    <span class="key">"next"</span>: <span class="str">"https://pictwo.toneflix.net/api/v1/list?page=3&amp;limit=30"</span>
  }
}</pre>
        </div>
      </div>

      <!-- INFO -->
      <div class="api-block">
        <div class="api-route">
          <span class="url-badge badge-get">GET</span>
          <code>/api/v1/id/<span class="hl">:id</span>/info</code>
        </div>
        <div class="api-route">
          <span class="url-badge badge-get">GET</span>
          <code>/api/v1/seed/<span class="hl">:seed</span>/info</code>
        </div>
        <p class="api-desc">Returns metadata for a single image by file ID or seed. The seed endpoint resolves which
          image the seed maps to and returns that image's details — useful for confirming what a seed will produce
          before embedding it.</p>

        <div class="api-response">
          <div class="api-response-bar">Response · object</div>
          <pre>{
  <span class="key">"id"</span>: <span class="str">"60001"</span>,
  <span class="key">"url"</span>: <span class="str">"{{config('app.url')}}/api/v1/id/60001/info"</span>,
  <span class="key">"width"</span>: <span class="num">800</span>,
  <span class="key">"height"</span>: <span class="num">600</span>,
  <span class="key">"category"</span>: <span class="str">"technology"</span>,
  <span class="key">"download_url"</span>: <span class="str">"{{config('app.url')}}/api/v1/id/60001/800/600"</span>
}</pre>
        </div>

        <p class="api-desc" style="font-size:0.78rem"><code
            style="font-family:var(--mono);font-size:0.8em;color:var(--accent)">links.prev</code> and <code
            style="font-family:var(--mono);font-size:0.8em;color:var(--accent)">links.next</code> are omitted when there
          is no previous or next page.</p>

        <div class="api-params">
          <div class="api-param" style="background:var(--surface-2);border-bottom:1px solid var(--line)">
            <span
              style="font-family:var(--mono);font-size:0.65rem;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;color:var(--ink-3);grid-column:1/-1">Response
              fields</span>
          </div>
          <div class="api-param">
            <span class="api-param-name">id</span>
            <span class="api-param-default">string</span>
            <span class="api-param-desc">Filename without extension — use in image routes</span>
          </div>
          <div class="api-param">
            <span class="api-param-name">width / height</span>
            <span class="api-param-default">number</span>
            <span class="api-param-desc">Native dimensions of the source file</span>
          </div>
          <div class="api-param">
            <span class="api-param-name">category</span>
            <span class="api-param-default">string</span>
            <span class="api-param-desc">Parent directory name</span>
          </div>
          <div class="api-param">
            <span class="api-param-name">download_url</span>
            <span class="api-param-default">string</span>
            <span class="api-param-desc">Ready-to-use image URL at 800×600</span>
          </div>
        </div>
      </div>

    </div>
  </section>

  <section id="filters">
    <div class="section-tag">Image processing</div>
    <div class="section-title">Filters</div>
    <p class="section-sub">Stack filters with commas. Filters that accept a value use the <code
        style="font-family:var(--mono);font-size:0.85em;color:var(--accent)">filter:value</code> syntax.</p>
    <div class="filters-grid">
      <div class="filter-card">
        <div class="filter-name">blur <span class="filter-param">:sigma</span></div>
        <div class="filter-desc">Gaussian blur. Amount 1–100 (default 2).</div>
        <div class="filter-example">?filters=blur:10</div>
      </div>
      <div class="filter-card">
        <div class="filter-name">greyscale</div>
        <div class="filter-desc">Convert to greyscale. Also accepts <code
            style="font-family:var(--mono);font-size:0.8em">grayscale</code>.</div>
        <div class="filter-example">?filters=greyscale</div>
      </div>
      <div class="filter-card">
        <div class="filter-name">sharpen</div>
        <div class="filter-desc">Increase image sharpness using an unsharp mask.</div>
        <div class="filter-example">?filters=sharpen</div>
      </div>
      <div class="filter-card">
        <div class="filter-name">invert</div>
        <div class="filter-desc">Invert all colours in the image (negate).</div>
        <div class="filter-example">?filters=invert</div>
      </div>
      <div class="filter-card">
        <div class="filter-name">normalize</div>
        <div class="filter-desc">Stretch contrast to full dynamic range.</div>
        <div class="filter-example">?filters=normalize</div>
      </div>
      <div class="filter-card">
        <div class="filter-name">flip / flop</div>
        <div class="filter-desc">Mirror vertically (flip) or horizontally (flop).</div>
        <div class="filter-example">?filters=flip,flop</div>
      </div>
      <div class="filter-card" style="grid-column:1/-1">
        <div class="filter-name">combining filters</div>
        <div class="filter-desc">All filters can be combined in a single request by separating them with commas.</div>
        <div class="filter-example">?filters=greyscale,blur:5,sharpen</div>
      </div>
    </div>
  </section>

  <section id="playground">
    <div class="section-tag">Interactive</div>
    <div class="section-title">Playground</div>
    <p class="section-sub">Build a URL and preview the result — no setup needed.</p>

    <div class="playground-inner">
      <div class="pg-form">
        <label>
          Base URL
          <input type="text" id="pg-base" value="{{config('app.url')}}" placeholder="{{config('app.url')}}" />
        </label>
        <label>
          Route style
          <select id="pg-style">
            <option value="picsum">Picsum — /{width}/{height}</option>
            <option value="toneflix">Lorem Toneflix — /images/{category}</option>
            <option value="id">By ID — /id/{id}/{width}/{height}</option>
            <option value="category">By category — /category/{cat}/{w}/{h}</option>
            <option value="seed">Seeded — /seed/{seed}/{width}/{height}</option>
          </select>
        </label>
        <div class="pg-row" id="pg-dims-row">
          <label>Width<input type="number" id="pg-w" value="800" min="1" max="4000" /></label>
          <label>Height<input type="number" id="pg-h" value="600" min="1" max="4000" /></label>
        </div>
        <label id="pg-cat-label" style="display:none">
          Category
          <input type="text" id="pg-cat" value="nature" placeholder="nature, avatar, technology…" />
        </label>
        <label id="pg-id-label" style="display:none">
          Image ID
          <input type="text" id="pg-id" value="10001" placeholder="file name without extension" />
        </label>
        <label id="pg-seed-label" style="display:none">
          Seed
          <input type="text" id="pg-seed" value="my-app-123" placeholder="any string" />
        </label>
        <label>
          Format
          <select id="pg-fmt">
            <option value="">jpeg (default)</option>
            <option value=".webp">webp</option>
            <option value=".avif">avif</option>
            <option value=".png">png</option>
          </select>
        </label>
        <label>Filters</label>
        <div class="checkbox-group" id="pg-filters">
          <span class="chip" data-filter="greyscale">greyscale</span>
          <span class="chip" data-filter="blur:5">blur</span>
          <span class="chip" data-filter="sharpen">sharpen</span>
          <span class="chip" data-filter="invert">invert</span>
          <span class="chip" data-filter="normalize">normalize</span>
          <span class="chip" data-filter="flip">flip</span>
        </div>
        <label id="pg-text-label">
          Text overlay (optional)
          <input type="text" id="pg-text" placeholder="Leave blank for none, or type text" />
        </label>
        <button class="pg-generate" onclick="buildUrl()">Generate URL →</button>
      </div>

      <div class="pg-preview" id="pg-preview-box">
        <div class="pg-placeholder" id="pg-placeholder">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
            <rect x="3" y="3" width="18" height="18" rx="2" />
            <circle cx="8.5" cy="8.5" r="1.5" />
            <path d="m21 15-5-5L5 21" />
          </svg>
          Hit "Generate URL" to preview
        </div>
      </div>
    </div>
  </section>

  <footer>
    <span>© 2025 {{app_name}}. Released under the MIT License.</span>
    <span>Compatible with <a href="https://lorem.toneflix.com.ng" target="_blank">Lorem Toneflix</a> API</span>
  </footer>

  <script>
    const BASE_URL = (function () {
      return '{{config('app.url')}}'
    })()

    // Bust cache on each reload by appending a random query param (acts as seed)
    let reloadNonce = Date.now()

    function tileUrl (tile) {
      const w = tile.dataset.w || 800
      const h = tile.dataset.h || 600
      const route = tile.dataset.route
      const nonce = `_r=${reloadNonce + parseInt(tile.dataset.w || '0')}`

      switch (route) {
        case 'random':
          return `${BASE_URL}/${w}/${h}?${nonce}`
        case 'seed':
          return `${BASE_URL}/seed/${tile.dataset.seed}/${w}/${h}`
        case 'filter':
          return `${BASE_URL}/${w}/${h}?filters=${tile.dataset.filter}&${nonce}`
        case 'category':
          return `${BASE_URL}/images/${tile.dataset.cat}?w=${w}&h=${h}&${nonce}`
        default:
          return `${BASE_URL}/${w}/${h}?${nonce}`
      }
    }

    function loadMosaic () {
      document.querySelectorAll('#mosaic .mosaic-item').forEach(tile => {
        const img = tile.querySelector('img')
        img.classList.remove('loaded')
        const url = tileUrl(tile)
        // Swap src — browser fetches new image
        img.onload = () => img.classList.add('loaded')
        img.onerror = () => { img.style.display = 'none' }
        img.src = url
      })
    }

    function reloadSamples () {
      reloadNonce = Date.now()
      const btn = document.getElementById('reload-btn')
      btn.classList.add('spinning')
      loadMosaic()
      setTimeout(() => btn.classList.remove('spinning'), 500)
    }

    // Kick off on page load
    loadMosaic()

    function loadCategories () {
      document.querySelectorAll('#categories-grid .cat-card').forEach(card => {
        const cat = card.dataset.cat
        const img = card.querySelector('img')
        // 4:3 crop at 480×360 — small enough to load fast, sharp enough to look good.
        // The seed param makes it deterministic so the card always shows the same image.
        img.onload = () => img.classList.add('loaded')
        img.onerror = () => { img.style.opacity = '0'; }
        img.src = `${BASE_URL}/images/${encodeURIComponent(cat)}?w=480&h=360&seed=cover`
      })
    }

    loadCategories()

    // Clicking a category card pre-fills the playground and scrolls to it.
    function prefillCategory (cat) {
      // Switch to Toneflix style and set the category field
      const styleEl = document.getElementById('pg-style')
      styleEl.value = 'toneflix'
      updateFields()
      document.getElementById('pg-cat').value = cat
    }

    document.querySelectorAll('.chip').forEach(c => {
      c.addEventListener('click', () => c.classList.toggle('active'))
    })

    const pgStyle = document.getElementById('pg-style')
    function updateFields () {
      const v = pgStyle.value
      document.getElementById('pg-cat-label').style.display = (v === 'toneflix' || v === 'category') ? '' : 'none'
      document.getElementById('pg-id-label').style.display = v === 'id' ? '' : 'none'
      document.getElementById('pg-seed-label').style.display = v === 'seed' ? '' : 'none'
    }
    pgStyle.addEventListener('change', updateFields)
    updateFields()

    function buildUrl () {
      const base = document.getElementById('pg-base').value.replace(/\/$/, '') || BASE_URL
      const style = pgStyle.value
      const w = document.getElementById('pg-w').value || 800
      const h = document.getElementById('pg-h').value || 600
      const fmt = document.getElementById('pg-fmt').value
      const cat = document.getElementById('pg-cat').value.trim() || 'nature'
      const imgId = document.getElementById('pg-id').value.trim() || 'image-01'
      const seed = document.getElementById('pg-seed').value.trim() || 'seed-1'
      const text = document.getElementById('pg-text').value.trim()

      const active = [...document.querySelectorAll('.chip.active')].map(c => c.dataset.filter).join(',')

      let path = ''
      const params = new URLSearchParams()

      switch (style) {
        case 'picsum': path = `/${w}/${h}${fmt}`; break
        case 'toneflix': path = `/images/${cat}`; params.set('w', w); params.set('h', h); break
        case 'id': path = `/id/${imgId}/${w}/${h}${fmt}`; break
        case 'category': path = `/category/${cat}/${w}/${h}${fmt}`; break
        case 'seed': path = `/seed/${seed}/${w}/${h}${fmt}`; break
      }

      if (active) {
        if (style === 'toneflix') {
          params.set('filters', active)
        } else {
          active.split(',').forEach(f => {
            const [name, val] = f.split(':')
            if (name === 'greyscale') params.set('grayscale', '1')
            else if (name === 'blur') params.set('blur', val || '5')
            else params.append('filters', f)
          })
        }
      }
      if (text) params.set('text', text)

      const qs = params.toString()
      const url = base + path + (qs ? '?' + qs : '')

      const box = document.getElementById('pg-preview-box')
      document.getElementById('pg-placeholder').style.display = 'none'
      box.querySelector('img')?.remove()
      box.querySelector('.pg-url-bar')?.remove()

      const img = document.createElement('img')
      img.src = url
      img.alt = 'Generated placeholder'
      img.onerror = () => { img.style.display = 'none' }
      box.prepend(img)

      const bar = document.createElement('div')
      bar.className = 'pg-url-bar'
      bar.innerHTML = `<span>${url}</span><button class="pg-copy" onclick="navigator.clipboard.writeText('${url.replace(/'/g, "\\'")}');this.textContent='✓ copied'">copy</button>`
      box.appendChild(bar)
    }
  </script>
</body>

</html>